# GrantFlow Environment Configuration
# Copy to .env and fill in your values

# =============================================================================
# APP CONFIGURATION
# =============================================================================
NODE_ENV=production
DOMAIN=grantflow.pl
NEXTAUTH_URL=https://grantflow.pl
NEXTAUTH_SECRET=your-super-secret-nextauth-key-min-32-chars-long

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://postgres:your-secure-password@db:5432/grantflow
DB_PASSWORD=your-secure-database-password

# =============================================================================
# PAYMENT PROVIDERS
# =============================================================================

# Przelewy24 (Traditional)
PRZELEWY24_MERCHANT_ID=123456
PRZELEWY24_API_KEY=your-p24-api-key
PRZELEWY24_CRC=your-p24-crc-key

# Open Banking (AIS/PIS)
OB_CLIENT_ID=your-open-banking-client-id
OB_CLIENT_SECRET=your-open-banking-secret
OB_REDIRECT_URI=https://grantflow.pl/api/payments/callback

# =============================================================================
# SEARCH ENGINE (Meilisearch)
# =============================================================================
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=your-meili-master-key

# =============================================================================
# AI/ML SERVICES
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key

# =============================================================================
# EMAIL SERVICE (AWS SES / SMTP)
# =============================================================================
SMTP_HOST=email-smtp.eu-central-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@grantflow.pl
EMAIL_FROM_NAME=GrantFlow.pl

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# =============================================================================
# SCRAPING & DATA COLLECTION
# =============================================================================
SCRAPER_API_KEY=internal-api-key-for-scrapers
# Bright Data / Oxylabs Proxy (optional but recommended)
PROXY_URL=http://user:pass@proxy.provider.com:22225

# =============================================================================
# BACKUP STORAGE (AWS S3)
# =============================================================================
BACKUP_S3_BUCKET=grantflow-backups
BACKUP_AWS_KEY=your-aws-access-key
BACKUP_AWS_SECRET=your-aws-secret-key
AWS_REGION=eu-central-1

# =============================================================================
# SECURITY
# =============================================================================
# Rate Limiting (requests per minute)
RATE_LIMIT_GENERAL=100
RATE_LIMIT_API=60
RATE_LIMIT_AUTH=10

# JWT Configuration
JWT_SECRET=your-jwt-secret-separate-from-nextauth
JWT_EXPIRES_IN=7d

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_OPEN_BANKING=true
ENABLE_P24=true
ENABLE_AUTO_FILL=true
ENABLE_SCRAPING=true

# =============================================================================
# ADMIN CONFIGURATION
# =============================================================================
ADMIN_EMAIL=admin@grantflow.pl
ADMIN_PASSWORD_HASH=$2b$10$... # bcrypt hash

# =============================================================================
# EXTERNAL APIs
# =============================================================================
# GUS API (for NIP/REGON validation)
GUS_API_KEY=your-gus-api-key

# CEIDG API (for company data)
CEIDG_API_KEY=your-ceidg-api-key